#!/usr/bin/env bash

# PDU Cluster Shell (pdu-clush) -- Parallel SSH execution tool for Vertiv PDUs
#
# Author: SergioZ3R0
# Date: 2026-06-12
#
# Description: Executes commands across Vertiv Geist PDUs in parallel using sshpass
#              and aggregates identical outputs similarly to ClusterShell (clush).
#

if [ $# -lt 4 ]; then
    echo "Usage: pdu-clush <pdu_ranges_or_@groups> <username> <password> <pdu_command>"
    echo "Example (Query): pdu-clush 172.17.167.[31-34] admin Pwd2024 get conf time"
    echo "Example (Set):   pdu-clush 172.17.167.[31-34] admin Pwd2024 'set auth = { \"admin\": { \"password\": \"NewPass\" } }'"
    exit 1
fi

input="$1"
username="$2"
password="$3"
# Grab the 4th argument and all subsequent ones, preserving spaces and quotes
pducmd="${@:4}"

declare -A output_map
declare -A output_content
all_nodes=()

# --- CLUSTERSHELL GROUP INTEGRATION (@group) ---
if [[ "$input" == *@* ]]; then
    if command -v nodeset >/dev/null 2>&1; then
        input=$(nodeset -S, -e "$input" 2>/dev/null)
        if [ -z "$input" ]; then
            echo "Error: 'nodeset' failed to resolve the group. Check your ClusterShell configuration."
            exit 1
        fi
    else
        echo "Error: '@' group syntax detected but 'nodeset' command is not found."
        exit 1
    fi
fi
# -----------------------------------------------

# --- INTELLIGENT RANGE PARSER ---
sanitized_input=""
in_brackets=0
for (( i=0; i<${#input}; i++ )); do
    char="${input:$i:1}"
    if [[ "$char" == "[" ]]; then in_brackets=1; fi
    if [[ "$char" == "]" ]]; then in_brackets=0; fi
    
    if [[ "$char" == "," && $in_brackets -eq 0 ]]; then
        sanitized_input+=" "
    else
        sanitized_input+="$char"
    fi
done

for group in $sanitized_input; do
    if [[ "$group" =~ ^(.*)\[(.*)\]$ ]]; then
        prefix="${BASH_REMATCH[1]}"
        inner="${BASH_REMATCH[2]}"
        
        IFS=',' read -r -a inner_groups <<< "$inner"
        for item in "${inner_groups[@]}"; do
            if [[ "$item" =~ ^([0-9]+)-([0-9]+)$ ]]; then
                start="${BASH_REMATCH[1]}"
                end="${BASH_REMATCH[2]}"
                width=${#start}
                for ((i=10#$start; i<=10#$end; i++)); do
                    printf -v node "%0${width}d" $i
                    all_nodes+=("${prefix}:::${node}")
                done
            elif [[ "$item" =~ ^([0-9]+)$ ]]; then
                all_nodes+=("${prefix}:::${item}")
            fi
        done
    elif [[ -n "$group" ]]; then
        if [[ "$group" =~ ^(.*[^0-9])([0-9]+)$ ]]; then
            all_nodes+=("${BASH_REMATCH[1]}:::${BASH_REMATCH[2]}")
        else
            all_nodes+=("${group}:::")
        fi
    fi
done
# -------------------------------------

# --- TRUE PARALLEL EXECUTION ENGINE (SSH) ---
tmpdir=$(mktemp -d /tmp/pdu-clush.XXXXXX)
trap 'rm -rf "$tmpdir"' EXIT

for entry in "${all_nodes[@]}"; do
    pfx="${entry%%:::*}"
    node="${entry##*:::}"

    if [[ -n "$node" ]]; then
        fullname="${pfx}${node}"
    else
        fullname="${pfx}"
    fi

    safe_name="${pfx}_${node}"

    # Launch background subshell to execute SSH without blocking the terminal
    (
        # Standard SSH execution without TTY allocation flags
        # Added ConnectTimeout=3 so the script moves on quickly if a PDU is offline/dead
        output=$(sshpass -p "$password" ssh -o StrictHostKeyChecking=no -o ConnectTimeout=3 "${username}@${fullname}" "$pducmd" 2>&1)
        
        printf "%s\n" "$output" > "$tmpdir/${safe_name}.out"
    ) &
done

wait
# --------------------------------------

# Group identical outputs using MD5 hashing
for entry in "${all_nodes[@]}"; do
    pfx="${entry%%:::*}"
    node="${entry##*:::}"
    safe_name="${pfx}_${node}"

    if [[ -f "$tmpdir/${safe_name}.out" ]]; then
        output=$(cat "$tmpdir/${safe_name}.out")
    else
        output=""
    fi

    key=$(printf "%s" "$output" | md5sum | cut -d' ' -f1)

    output_map[$key]+=" ${pfx}:::${node}"
    output_content[$key]="$output"
done

# --- OUTPUT AGGREGATION GENERATION ---
for key in "${!output_map[@]}"; do
    entries=$(echo "${output_map[$key]}" | tr ' ' '\n' | grep -v '^$' | sort -V)
    count=$(echo "$entries" | wc -l)

    full_node_list=""
    for entry in $entries; do
        pfx="${entry%%:::*}"
        node="${entry##*:::}"
        full_node_list+="${pfx}${node},"
    done
    full_node_list="${full_node_list%,}"

    if command -v nodeset >/dev/null 2>&1; then
        header=$(nodeset -f "$full_node_list")
    else
        header=""
        declare -A prefix_nodes
        for entry in $entries; do
            pfx="${entry%%:::*}"
            node="${entry##*:::}"
            prefix_nodes[$pfx]+=" $node"
        done

        for pfx in $(echo "${!prefix_nodes[@]}" | tr ' ' '\n' | sort); do
            nodes=$(echo "${prefix_nodes[$pfx]}" | tr ' ' '\n' | grep -v '^$' | sort -V)
            first_num=$(echo "$nodes" | head -1)

            if [[ -z "$first_num" ]]; then
                header="${header}${pfx},"
                continue
            fi

            width=${#first_num}
            ranges=$(echo "$nodes" | awk -v w="$width" '
                function pad(n) { return sprintf("%0" w "d", n+0) }
                {
                    cur = $1+0
                    if (NR == 1) { first = cur; prev = cur; next }
                    if (cur == prev + 1) { prev = cur }
                    else {
                        if (first == prev) printf "%s,", pad(first)
                        else printf "%s-%s,", pad(first), pad(prev)
                        first = cur; prev = cur
                    }
                }
                END {
                    if (first == prev) printf "%s", pad(first)
                    else printf "%s-%s", pad(first), pad(prev)
                }
            ')
            header+="${pfx}[${ranges}],"
        done
        header="${header%,}"
        unset prefix_nodes
    fi

    echo "---------------"
    echo "${header} (${count})"
    echo "---------------"
    echo "${output_content[$key]}"
done
